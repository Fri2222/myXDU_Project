@article{WangLuoJiYuGaiJinByteTrackSuanFaDeHongWaiDiMianDuoMuBiaoGenZongFangFa2023,
  title = {基于改进ByteTrack算法的红外地面多目标跟踪方法},
  author = {{王雒} and {李飚} and {傅瑞罡}},
  date = {2023},
  journaltitle = {计算机科学},
