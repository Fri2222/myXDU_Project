  urldate = {2026-05-02},
  abstract = {The extended Kalman filter (EKF) is probably the most widely used estimation algorithm for nonlinear systems. However, more than 35 years of experience in the estimation community has shown that is difficult to implement, difficult to tune, and only reliable for systems that are almost linear on the time scale of the updates. Many of these difficulties arise from its use of linearization. To overcome this limitation, the unscented transformation (UT) was developed as a method to propagate mean and covariance information through nonlinear transformations. It is more accurate, easier to implement, and uses the same order of calculations as linearization. This paper reviews the motivation, development, use, and implications of the UT.},
  keywords = {/unread,Chemical processes,Control systems,Filtering,Kalman filters,Navigation,Nonlinear control systems,Nonlinear systems,Particle tracking,Target tracking,Vehicles}
}

@article{kimApplicationRecurrentNeuralNetwork2023,
  title = {Application of {{Recurrent Neural-Network}} Based {{Kalman Filter}} for {{Uncertain Target Models}}},
  author = {Kim, DongBeom and Jeong, Daekyo and Lim, Jaehyuk and Min, Sawon and Moon, Jun},
  date = {2023-02-05},
  journaltitle = {Journal of the Korea Institute of Military Science and Technology},
  shortjournal = {Journal of the Korea Institute of Military Science and Technology},
  volume = {26},
  pages = {10--21},
  doi = {10.9766/KIMST.2023.26.1.010},
  abstract = {For various target tracking applications, it is well known that the Kalman filter is the optimal estimator(in the minimum mean-square sense) to predict and estimate the state(position and/or velocity) of linear dynamical systems driven by Gaussian stochastic noise. In the case of nonlinear systems, Extended Kalman filter(EKF) and/or Unscented Kalman filter(UKF) are widely used, which can be viewed as approximations of the(linear) Kalman filter in the sense of the conditional expectation. However, to implement EKF and UKF, the exact dynamical model information and the statistical information of noise are still required. In this paper, we propose the recurrent neural-network based Kalman filter, where its Kalman gain is obtained via the proposed GRU-LSTM based neural-network framework that does not need the precise model information as well as the noise covariance information. By the proposed neural-network based Kalman filter, the state estimation performance is enhanced in terms of the tracking error, which is verified through various linear and nonlinear tracking problems with incomplete model and statistical covariance information.},
  keywords = {/unread},
  file = {H:\Literature\Official\storage\YZHRFW59\Kim 等 - 2023 - Application of Recurrent Neural-Network based Kalman Filter for Uncertain Target Models.pdf}
}

@article{kulkarniHybridEKFLSTMFramework2025,
  title = {A Hybrid {{EKF-LSTM}} Framework with {{GA-tuned}} Noise Covariance for Enhanced Time Series Forecasting},
  author = {Kulkarni, Ashvini and Paul, Augusta Sophy Beulet},
  date = {2025-09-01},
  journaltitle = {Engineering Research Express},
  volume = {7},
  pages = {035266},
  publisher = {IOP},
  doi = {10.1088/2631-8695/adf9be},
  url = {https://ui.adsabs.harvard.edu/abs/2025ERExp...7c5266K},
  urldate = {2026-05-02},
  abstract = {Accurate navigation state estimation is essential for control systems, where internal states must be inferred from noisy sensor inputs. Traditional Extended Kalman Filter (EKF) methods often face limitations when handling nonlinearities and sensor noise. To overcome these challenges, this study proposes a hybrid model that integrates EKF with Long Short-Term Memory (LSTM) networks and multi-head attention mechanisms to leverage temporal dependencies for improved future state prediction. Additionally, a Genetic algorithm (GA) is employed to optimize the process noise covariance matrix (Q), enhancing the adaptability of the EKF. The inclusion of 1D convolutional (Conv1D) layers enables effective feature extraction from accelerometer and gyroscope data, further boosting estimation accuracy. Compared to conventional EKF techniques, the proposed hybrid EKF-LSTM model augmented with attention and GA optimized Q achieves substantial reductions in Mean Squared Error (MSE), Root Mean Squared Error (RMSE), and Mean Absolute Error (MAE), offering a robust and reliable solution for navigation in dynamic and noisy environments.},
  keywords = {/unread,Extended Kalman Filter (EKF),forecasting,genetic algorithm,Long-Short Term Memory (LSTM),state estimators,time series},
  annotation = {ADS Bibcode: 2025ERExp...7c5266K}
}

